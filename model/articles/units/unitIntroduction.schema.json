{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "unitIntroduction.schema.json",
  "title": "Introduction unit",
  "version": "0.1.0",
  "description": "Opening chunk for a Markdown file or HTML5 page. It normally contains the H1 and orientation text.",
  "type": "object",
  "allOf": [{ "$ref": "unitShared.schema.json#/$defs/unitBase" }],
  "properties": {
    "unitType": { "const": "introduction" },
    "informationType": { "enum": ["concept", "fact", "mixed", "unknown"] },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "components/compHeaderH1.schema.json" },
          { "$ref": "components/compParagraph.schema.json" },
          { "$ref": "components/compListUnordered.schema.json" },
          { "$ref": "components/compUnknown.schema.json" }
        ]
      },
      "contains": { "$ref": "components/compHeaderH1.schema.json" }
    }
  },
  "required": ["unitType", "unitId", "informationType", "content"]
}
