{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "compHeaderH3.schema.json",
  "title": "H3 heading component",
  "version": "0.1.0",
  "description": "Third-level section heading.",
  "x-markdown-regex": "^###\\s+.+$",
  "x-html-element": "h3",
  "type": "object",
  "allOf": [{ "$ref": "componentShared.schema.json#/$defs/componentBase" }],
  "properties": {
    "componentType": { "const": "compHeaderH3" },
    "level": { "const": 3 }
  },
  "required": ["componentType", "level", "markdown"]
}
