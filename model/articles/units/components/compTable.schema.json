{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "compTable.schema.json",
  "title": "Table component",
  "version": "0.1.0",
  "description": "Block component for tabular data. Its content must be table-row components.",
  "x-markdown-pattern": "GitHub-flavored Markdown pipe table.",
  "x-html-element": "table",
  "type": "object",
  "allOf": [{ "$ref": "componentShared.schema.json#/$defs/componentBase" }],
  "properties": {
    "componentType": { "const": "compTable" },
    "columnCount": { "type": "integer", "minimum": 1 },
    "rowCount": { "type": "integer", "minimum": 1 },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "compTableRow.schema.json" },
      "contains": {
        "type": "object",
        "properties": { "rowRole": { "const": "header" } },
        "required": ["rowRole"]
      }
    }
  },
  "required": ["componentType", "columnCount", "rowCount", "content"]
}
