{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "compBlockQuote.schema.json",
  "title": "Block quote component",
  "version": "0.1.0",
  "description": "Block component for quoted content.",
  "x-markdown-regex": "^(>\\s?.+\\n?)+$",
  "x-html-element": "blockquote",
  "type": "object",
  "allOf": [{ "$ref": "componentShared.schema.json#/$defs/componentBase" }],
  "properties": {
    "componentType": { "const": "compBlockQuote" },
    "content": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "compParagraph.schema.json" },
          { "$ref": "compListUnordered.schema.json" },
          { "$ref": "attributes/sharedInLineElementProperties.schema.json" }
        ]
      }
    }
  },
  "required": ["componentType", "markdown"]
}
