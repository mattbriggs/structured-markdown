{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "compHeaderH4.schema.json",
  "title": "H4 heading component",
  "version": "0.1.0",
  "description": "Fourth-level section heading.",
  "x-markdown-regex": "^####\\s+.+$",
  "x-html-element": "h4",
  "type": "object",
  "allOf": [{ "$ref": "componentShared.schema.json#/$defs/componentBase" }],
  "properties": {
    "componentType": { "const": "compHeaderH4" },
    "level": { "const": 4 }
  },
  "required": ["componentType", "level", "markdown"]
}
