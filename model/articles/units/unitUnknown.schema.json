{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "unitUnknown.schema.json",
  "title": "Unknown unit",
  "version": "0.1.0",
  "description": "Fallback chunk for source regions the parser cannot confidently triage into a known unit pattern.",
  "type": "object",
  "allOf": [{ "$ref": "unitShared.schema.json#/$defs/unitBase" }],
  "properties": {
    "unitType": { "const": "unknown" },
    "informationType": { "const": "unknown" },
    "triageStatus": { "const": "unknown" },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "components/sharedBlockElementProperties.schema.json" }
    }
  },
  "required": ["unitType", "unitId", "informationType", "triageStatus", "content"]
}
