{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "unitConcept.schema.json",
  "title": "Concept unit",
  "version": "0.1.0",
  "description": "Chunk that explains an idea, object, system, role, or relationship.",
  "type": "object",
  "allOf": [{ "$ref": "unitShared.schema.json#/$defs/unitBase" }],
  "properties": {
    "unitType": { "const": "concept" },
    "informationType": { "const": "concept" },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "components/sharedBlockElementProperties.schema.json" },
      "contains": {
        "oneOf": [
          { "$ref": "components/compParagraph.schema.json" },
          { "$ref": "components/compHeaderH2.schema.json" },
          { "$ref": "components/compHeaderH3.schema.json" }
        ]
      }
    }
  },
  "required": ["unitType", "unitId", "informationType", "content"]
}
