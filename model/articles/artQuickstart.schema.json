{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "artQuickstart.schema.json",
  "title": "Quickstart article",
  "version": "0.1.0",
  "description": "A specialized how-to article that helps a reader complete the first useful task quickly.",
  "type": "object",
  "allOf": [{ "$ref": "sharedArticle.schema.json#/$defs/articleBase" }],
  "properties": {
    "articleType": { "const": "quickstart" },
    "ditaType": { "const": "howto" },
    "informationType": { "const": "procedure" },
    "title": { "type": "string", "pattern": "^(Quickstart:|Quickstart -|Quickstart ).+" },
    "content": {
      "type": "array",
      "minItems": 2,
      "items": {
        "anyOf": [
          { "$ref": "units/unitIntroduction.schema.json" },
          { "$ref": "units/unitPrerequisites.schema.json" },
          { "$ref": "units/unitProcedure.schema.json" },
          { "$ref": "units/unitProcedureOrderedlist.schema.json" },
          { "$ref": "units/unitProcedureCodeblock.schema.json" },
          { "$ref": "units/unitLinkNextstep.schema.json" },
          { "$ref": "units/unitLinkRelated.schema.json" },
          { "$ref": "units/unitUnknown.schema.json" }
        ]
      },
      "contains": {
        "anyOf": [
          { "$ref": "units/unitProcedure.schema.json" },
          { "$ref": "units/unitProcedureOrderedlist.schema.json" },
          { "$ref": "units/unitProcedureCodeblock.schema.json" }
        ]
      }
    }
  },
  "required": ["schema", "version", "articleId", "articleType", "ditaType", "informationType", "title", "content"]
}
