        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Start Line"
    },
    "end_line": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "End Line"
    }
  },
  "required": [
    "ref_type",
    "href"
  ],
  "title": "Reference",
  "type": "object"
