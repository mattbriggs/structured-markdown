      "type": "string"
    },
    "ref_type": {
      "title": "Ref Type",
      "type": "string"
    },
    "href": {
      "title": "Href",
      "type": "string"
    },
    "text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text"
    },
    "alt_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
