{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "unitTroubleshooting.schema.json",
  "title": "Troubleshooting unit",
  "version": "0.1.0",
  "description": "Chunk that captures a symptom, possible causes, diagnostic checks, and resolution steps.",
  "type": "object",
  "allOf": [{ "$ref": "unitShared.schema.json#/$defs/unitBase" }],
  "properties": {
    "unitType": { "const": "troubleshooting" },
    "informationType": { "const": "process" },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "components/sharedBlockElementProperties.schema.json" }
    }
  },
  "required": ["unitType", "unitId", "informationType", "content"]
}
