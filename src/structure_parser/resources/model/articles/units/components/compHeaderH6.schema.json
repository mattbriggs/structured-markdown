{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "compHeaderH6.schema.json",
  "title": "H6 heading component",
  "version": "0.1.0",
  "description": "Sixth-level section heading.",
  "x-markdown-regex": "^######\\s+.+$",
  "x-html-element": "h6",
  "type": "object",
  "allOf": [{ "$ref": "componentShared.schema.json#/$defs/componentBase" }],
  "properties": {
    "componentType": { "const": "compHeaderH6" },
    "level": { "const": 6 }
  },
  "required": ["componentType", "level", "markdown"]
}
