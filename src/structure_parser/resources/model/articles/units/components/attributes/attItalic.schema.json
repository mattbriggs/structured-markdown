{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "attItalic.schema.json",
  "title": "Italic attribute",
  "version": "0.1.0",
  "description": "Inline italic text.",
  "x-markdown-regex": "\\*([^*]+)\\*|_([^_]+)_",
  "x-html-element": "i",
  "type": "object",
  "allOf": [{ "$ref": "attributeShared.schema.json#/$defs/attributeBase" }],
  "properties": {
    "attType": { "const": "attItalic" }
  },
  "required": ["attType", "markdown"]
}
