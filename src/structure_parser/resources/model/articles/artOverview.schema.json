{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "artOverview.schema.json",
  "title": "Overview article",
  "version": "0.1.0",
  "description": "A specialized concept article whose title commonly explains what a product, service, or feature is.",
  "type": "object",
  "allOf": [{ "$ref": "sharedArticle.schema.json#/$defs/articleBase" }],
  "properties": {
    "articleType": { "const": "overview" },
    "ditaType": { "const": "concept" },
    "informationType": { "const": "concept" },
    "title": { "type": "string", "pattern": "^(What is|Overview of|Introduction to) .+" },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          { "$ref": "units/unitIntroduction.schema.json" },
          { "$ref": "units/unitConcept.schema.json" },
          { "$ref": "units/unitPrinciple.schema.json" },
          { "$ref": "units/unitFact.schema.json" },
          { "$ref": "units/unitLinkRelated.schema.json" },
          { "$ref": "units/unitUnknown.schema.json" }
        ]
      },
      "contains": { "$ref": "units/unitConcept.schema.json" }
    }
  },
  "required": ["schema", "version", "articleId", "articleType", "ditaType", "informationType", "title", "content"]
}
