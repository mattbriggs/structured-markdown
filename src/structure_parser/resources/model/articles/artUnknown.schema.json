{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "artUnknown.schema.json",
  "title": "Unknown article",
  "version": "0.1.0",
  "description": "Fallback article pattern for parsed Markdown or HTML5 pages that cannot be triaged into a known article type.",
  "type": "object",
  "allOf": [{ "$ref": "sharedArticle.schema.json#/$defs/articleBase" }],
  "properties": {
    "articleType": { "const": "unknown" },
    "ditaType": { "const": "topic" },
    "informationType": { "const": "unknown" },
    "triageStatus": { "const": "unknown" },
    "content": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "units/sharedUnits.schema.json" }
    }
  },
  "required": ["schema", "version", "articleId", "articleType", "ditaType", "informationType", "triageStatus", "content"]
}
