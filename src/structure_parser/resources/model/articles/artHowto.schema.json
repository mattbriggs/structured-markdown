{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "artHowto.schema.json",
  "title": "How-to article",
  "version": "0.1.0",
  "description": "A root-level article pattern for task-oriented instructions that show how to accomplish a goal.",
  "type": "object",
  "allOf": [{ "$ref": "sharedArticle.schema.json#/$defs/articleBase" }],
  "properties": {
    "articleType": { "const": "howto" },
    "ditaType": { "const": "howto" },
    "informationType": { "const": "procedure" },
    "content": {
      "type": "array",
      "minItems": 2,
      "items": {
        "anyOf": [
          { "$ref": "units/unitIntroduction.schema.json" },
          { "$ref": "units/unitPrerequisites.schema.json" },
          { "$ref": "units/unitProcedure.schema.json" },
          { "$ref": "units/unitProcedureOrderedlist.schema.json" },
          { "$ref": "units/unitProcedureCodeblock.schema.json" },
          { "$ref": "units/unitFact.schema.json" },
          { "$ref": "units/unitReference.schema.json" },
          { "$ref": "units/unitLinkNextstep.schema.json" },
          { "$ref": "units/unitLinkRelated.schema.json" },
          { "$ref": "units/unitUnknown.schema.json" }
        ]
      },
      "contains": {
        "anyOf": [
          { "$ref": "units/unitProcedure.schema.json" },
          { "$ref": "units/unitProcedureOrderedlist.schema.json" },
          { "$ref": "units/unitProcedureCodeblock.schema.json" }
        ]
      }
    }
  },
  "required": ["schema", "version", "articleId", "articleType", "ditaType", "informationType", "content"]
}
